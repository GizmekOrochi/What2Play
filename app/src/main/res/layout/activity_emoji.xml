<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EmojiActivity">

    <Button
        android:id="@+id/buttonPrevious2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/previous_buttons"
        app:layout_constraintBottom_toBottomOf="@+id/buttonHome2"
        app:layout_constraintEnd_toStartOf="@+id/buttonHome2"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/buttonHome2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/home_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/buttonValidate2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/validate_buttons"
        app:layout_constraintBottom_toBottomOf="@+id/buttonHome2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/buttonHome2" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.050000012" />

    <TextView
        android:id="@+id/emoji_question_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap the emojis in order of preference"
        android:textAlignment="center"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView8" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:layout_constraintBottom_toTopOf="@+id/buttonHome2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/emoji_question_description">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridEmoji"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                app:columnCount="2">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBoomBap"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="4dp"
                    android:checkable="false"
                    android:clickable="true"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="🎤"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWestCoast"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:checkable="false"
                    android:clickable="true"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="🌴"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTrap"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="4dp"
                    android:checkable="false"
                    android:clickable="true"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="💥"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCloudRap"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:checkable="false"
                    android:clickable="true"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="🌫️"
                    android:textAlignment="center"
                    android:textSize="24sp" />

            </androidx.gridlayout.widget.GridLayout>

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                app:columnCount="2">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRankA1"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="4dp"
                    android:checkable="false"
                    android:clickable="false"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="◌"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRankB1"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:checkable="false"
                    android:clickable="false"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="◌"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRankA2"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="4dp"
                    android:checkable="false"
                    android:clickable="false"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="◌"
                    android:textAlignment="center"
                    android:textSize="24sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRankB2"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:checkable="false"
                    android:clickable="false"
                    android:gravity="center"
                    android:padding="0dp"
                    android:text="◌"
                    android:textAlignment="center"
                    android:textSize="24sp" />

            </androidx.gridlayout.widget.GridLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>